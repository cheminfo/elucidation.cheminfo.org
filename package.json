{
  "name": "elucidation.cheminfo.org",
  "version": "0.0.0",
  "private": true,
  "description": "Web interface for SECS: end-to-end structure elucidation from 1H NMR spectra",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build-challenges": "node scripts/build-challenges.ts",
    "check-types": "tsc --noEmit",
    "dev": "vite",
    "eslint": "eslint .",
    "eslint-fix": "eslint . --fix",
    "playwright": "playwright test",
    "preview": "vite preview",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.17.2",
    "@blueprintjs/icons": "^6.13.0",
    "@blueprintjs/select": "^6.3.3",
    "@preact/signals-react": "^3.10.3",
    "@zakodium/nmrium-core": "^0.7.44",
    "@zakodium/nmrium-core-plugins": "^0.7.60",
    "file-collection": "^6.6.1",
    "idb": "^8.0.3",
    "mf-parser": "^3.9.1",
    "ml-spectra-processing": "^14.29.2",
    "openchemlib": "^9.24.0",
    "openchemlib-utils": "^8.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-mf": "^3.1.1",
    "react-ocl": "^8.7.2",
    "react-plot": "^3.1.2",
    "react-science": "^20.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@zakodium/tsconfig": "^1.0.5",
    "eslint": "^9.39.5",
    "eslint-config-zakodium": "^20.1.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
