# Copy to .env: cp .env.example .env

# Deployment mode: uncomment exactly ONE line to choose how the service is exposed.
# With none uncommented, docker compose uses compose.yaml by default.
# COMPOSE_FILE=compose.yaml          # port-published (publishes PORT on the host)
# COMPOSE_FILE=compose.traefik.yaml  # behind a Traefik reverse proxy

# Host port for the frontend in the port-published mode.
PORT=10718
